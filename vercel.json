{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth/(.*)", "destination": "/api/auth.js" },
    { "source": "/api/courses/(.*)", "destination": "/api/courses.js" },
    { "source": "/api/students/(.*)", "destination": "/api/students.js" },
    { "source": "/api/admin/(.*)", "destination": "/api/admin.js" },
    { "source": "/api/projects/(.*)", "destination": "/api/projects.js" },
    { "source": "/api/batches/(.*)", "destination": "/api/batches.js" },
    { "source": "/api/modules/(.*)", "destination": "/api/modules.js" },
    { "source": "/api/videos/(.*)", "destination": "/api/videos.js" },
    { "source": "/api/attendance/(.*)", "destination": "/api/attendance.js" },
    { "source": "/api/youtube/(.*)", "destination": "/api/youtube.js" },
    { "source": "/api/announcements/(.*)", "destination": "/api/announcements.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/)(?:[^.]+$|$))", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": {
      "includeFiles": "server/db.js|server/app_factory.js|server/routes/**|server/services/**|server/middleware/**"
    }
  }
}
