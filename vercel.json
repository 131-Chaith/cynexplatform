{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/auth/(.*)", "dest": "/api/auth.js" },
    { "src": "/api/courses/(.*)", "dest": "/api/courses.js" },
    { "src": "/api/students/(.*)", "dest": "/api/students.js" },
    { "src": "/api/admin/(.*)", "dest": "/api/admin.js" },
    { "src": "/api/projects/(.*)", "dest": "/api/projects.js" },
    { "src": "/api/batches/(.*)", "dest": "/api/batches.js" },
    { "src": "/api/modules/(.*)", "dest": "/api/modules.js" },
    { "src": "/api/videos/(.*)", "dest": "/api/videos.js" },
    { "src": "/api/attendance/(.*)", "dest": "/api/attendance.js" },
    { "src": "/api/youtube/(.*)", "dest": "/api/youtube.js" },
    { "src": "/api/announcements/(.*)", "dest": "/api/announcements.js" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/*.js": {
      "includeFiles": "server/db.js|server/app_factory.js|server/routes/**|server/services/**|server/middleware/**"
    }
  }
}
