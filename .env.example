# ============================================================
# Cynex Portal — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database (Turso Cloud) ---
TURSO_DATABASE_URL=libsql://your-db-name.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# --- Auth ---
JWT_SECRET=your_jwt_secret_32_chars_minimum_here

# --- Server ---
PORT=5002
NODE_ENV=production

# --- Google OAuth (optional - for Google Meet integration) ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-render-backend.onrender.com/api/auth/google/callback
